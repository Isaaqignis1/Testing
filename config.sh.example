# copy to config.sh and fill in. the .job files in this repo source it from the repo root

# slurm
export CONDA_MODULE="apps/binapps/conda/miniforge3/25.9.1"   # blank if conda is already on PATH

# roots
export CONDA_ENVS_DIR="${HOME}/.conda/envs"

# conda env names, create these yourself
export ENV_PROKKA="prokka_env"
export ENV_PHASOMEIT="phasome_env"
export ENV_EGGNOG="eggnog"

# genome inputs
export GENOMES_ARCHAEA_DIR="${HOME}/scratch/genomes/atb.archaea"
export GENOMES_CONTROLS_DIR="${HOME}/project1/controls/genomes"
export ARCHAEA_FASTA_LIST="${HOME}/scratch/genomes/archaea_fasta_list.txt"
export CONTROLS_FASTA_LIST="${GENOMES_CONTROLS_DIR}/comparator_fasta_list.txt"

# prokka output
export PROKKA_OUT="${HOME}/scratch/prokka/all"
export PROKKA_CTRL_OUT="${HOME}/project1/controls/prokka"

# eggnog
export EGGNOG_DIR="${HOME}/project1/eggnog"
export EGGNOG_DB_DIR="${HOME}/project1/tools/eggnog_db"

# external tools
export PHASOMEIT_REPO="${HOME}/project1/tools/PhasomeIt"

# dataset construction
# AllTheBacteria metadata (tsv or csv, must contain sample_id + scientific_name)
export ATB_METADATA="${HOME}/scratch/genomes/atb.archaea/metadata.tsv"
# output of dataset/build_species_calls.py
export SPECIES_CALLS_DIR="${HOME}/project1/species_calls"
# output of dataset/build_genus_gff_lists.py
export GFF_LISTS_DIR="${HOME}/project1/genus_gff_lists"
# bacterial controls species map (kept under repo/standards in this repo)
export CONTROLS_SPECIES_TSV="${HOME}/project1/repo/standards/SpeciesCallsBacteria.tsv"

# phasomeit base dirs (one subdir per genus)
export PHASOME_ARCHAEA_BASE="${HOME}/scratch/phasome/genus_archaea"
export PHASOME_CONTROLS_BASE="${HOME}/project1/controls/phasome/genus"

# pipeline output dirs
export EXTRACTION_DIR="${HOME}/project1/Extraction"
export CLEANED_DIR="${HOME}/project1/Cleaned"
export QUANT_DIR="${HOME}/project1/quantification"
export ANALYSIS_DIR="${HOME}/project1/analysis"
