# =============================================================================
# archaea-pv-analysis - pipeline configuration
# =============================================================================
#
# This file is the single source of paths and settings for the pipeline.
#   1. cp config.sh.example config.sh
#   2. edit only the lines you need to change (most users edit nothing)
#   3. bash check_setup.sh   # confirms every path + tool works
#
# Inside the repo we keep ONLY: source code, job scripts, standards, env yamls.
# Data (raw downloads + derived outputs) lives on scratch, NOT inside the repo.
# Conda envs live wherever conda put them, NOT inside the repo.
#
# =============================================================================
# 1. ROOTS
# -----------------------------------------------------------------------------
# REPO_ROOT     auto-detected, do not edit.
# SCRATCH_ROOT  where downloaded data + derived data go. Default = your
#               scratch area on CSF. Override if you want it elsewhere.

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SCRATCH_ROOT="${SCRATCH_ROOT:-${HOME}/scratch/archaea-pv-analysis}"

# =============================================================================
# 2. CONDA / cluster
# -----------------------------------------------------------------------------
# CONDA_MODULE      the `module load` string that puts conda on PATH. Empty
#                   if conda is already on PATH globally. Change for clusters
#                   other than Manchester CSF.
# ENV_PROKKA        name of the conda env that has prokka installed.
# ENV_PHASOMEIT     name of the env with biopython + the python deps for
#                   PhasomeIt and the parsing scripts.
# ENV_EGGNOG        name of the env with eggnog-mapper installed.
#
# All three envs must already exist in your conda installation. setup.sh
# can create them from envs/*.yml if you don't have them yet.

CONDA_MODULE="${CONDA_MODULE:-apps/binapps/conda/miniforge3/25.9.1}"
ENV_PROKKA="${ENV_PROKKA:-prokka_env}"
ENV_PHASOMEIT="${ENV_PHASOMEIT:-phasome_env}"
ENV_EGGNOG="${ENV_EGGNOG:-eggnog_env}"

# =============================================================================
# 3. EXTERNAL TOOLS
# -----------------------------------------------------------------------------
# PHASOMEIT_REPO       where PhasomeIt is cloned. Default = inside SCRATCH_ROOT
#                      (NOT inside the repo). setup.sh clones it for you if
#                      this directory does not exist.
# PHASOMEIT_GIT_URL    only override if you have a fork.

PHASOMEIT_REPO="${PHASOMEIT_REPO:-${SCRATCH_ROOT}/external/PhasomeIt}"
PHASOMEIT_GIT_URL="${PHASOMEIT_GIT_URL:-https://github.com/JackAidley/PhasomeIt.git}"

# =============================================================================
# 4. WHAT TO ANALYSE
# -----------------------------------------------------------------------------
# ARCHAEA_GENERA_FILE     plain text, one GTDB-style genus per line. The
#                         downloader pulls every ATB assembly whose species
#                         call starts with one of these names. Edit this file
#                         to change the genus set.
# CONTROLS_SPECIES_TSV    TSV listing controls species + minimum strains per
#                         species. Default = Brucella + E. coli + Campylobacter,
#                         8 strains per species. Set to "" to skip controls.
# MIN_PER_SPECIES         retain only species with >= this many strains. A
#                         genus survives if ANY of its species clears the bar.

ARCHAEA_GENERA_FILE="${ARCHAEA_GENERA_FILE:-${REPO_ROOT}/standards/default_archaea_genera.txt}"
CONTROLS_SPECIES_TSV="${CONTROLS_SPECIES_TSV:-${REPO_ROOT}/standards/default_controls_species.tsv}"
MIN_PER_SPECIES="${MIN_PER_SPECIES:-5}"

# =============================================================================
# 5. WHERE INPUTS AND OUTPUTS LIVE
# -----------------------------------------------------------------------------
# INPUTS_DIR    raw downloads (ATB metadata, archaeal + controls fastas).
#               This is the only place the pipeline writes raw GB-scale data.
#               Default = ${SCRATCH_ROOT}/INPUTS.
# OUTPUTS_DIR   every derived artefact (Prokka, PhasomeIt, eggnog, figures).
#               Default = ${SCRATCH_ROOT}/OUTPUTS.
# LOGS_DIR      SLURM stdout/stderr land here. Default = ${OUTPUTS_DIR}/logs.

INPUTS_DIR="${INPUTS_DIR:-${SCRATCH_ROOT}/INPUTS}"
OUTPUTS_DIR="${OUTPUTS_DIR:-${SCRATCH_ROOT}/OUTPUTS}"
LOGS_DIR="${LOGS_DIR:-${OUTPUTS_DIR}/logs}"

# -- derived input paths (do not normally need editing) ----------------------
GENOMES_ARCHAEA_DIR="${INPUTS_DIR}/archaea/fasta"
GENOMES_CONTROLS_DIR="${INPUTS_DIR}/controls/fasta"
ATB_METADATA="${INPUTS_DIR}/archaea/atb_archaea_metadata.tsv"
ATB_TARBALL_CACHE="${INPUTS_DIR}/_tar_cache"
ARCHAEA_FASTA_LIST="${INPUTS_DIR}/archaea/fasta_list.txt"
CONTROLS_FASTA_LIST="${INPUTS_DIR}/controls/fasta_list.txt"
CONTROLS_GENUS_MAP="${INPUTS_DIR}/controls/controls_species.tsv"

# -- derived output paths (do not normally need editing) ---------------------
PROKKA_OUT="${OUTPUTS_DIR}/01_prokka/archaea"
PROKKA_CTRL_OUT="${OUTPUTS_DIR}/01_prokka/controls"
SPECIES_CALLS_DIR="${OUTPUTS_DIR}/02_dataset/species_calls"
GFF_LISTS_DIR="${OUTPUTS_DIR}/02_dataset/genus_gff_lists"
PHASOME_ARCHAEA_BASE="${OUTPUTS_DIR}/03_phasomeit/archaea"
PHASOME_CONTROLS_BASE="${OUTPUTS_DIR}/03_phasomeit/controls"
EXTRACTION_DIR="${OUTPUTS_DIR}/04_extraction"
EGGNOG_DIR="${OUTPUTS_DIR}/05_eggnog"
EGGNOG_DB_DIR="${EGGNOG_DIR}/db"
CLEANED_DIR="${OUTPUTS_DIR}/06_cleaned"
QUANT_DIR="${OUTPUTS_DIR}/07_quantification"
ANALYSIS_DIR="${OUTPUTS_DIR}/08_analysis"
FIGURES_DIR="${OUTPUTS_DIR}/09_figures"

# =============================================================================
# 6. SLURM
# -----------------------------------------------------------------------------
SLURM_PARTITION="${SLURM_PARTITION:-multicore}"

# =============================================================================
# Export everything so .job scripts see the values
# =============================================================================
export REPO_ROOT SCRATCH_ROOT \
       CONDA_MODULE ENV_PROKKA ENV_PHASOMEIT ENV_EGGNOG \
       PHASOMEIT_REPO PHASOMEIT_GIT_URL \
       ARCHAEA_GENERA_FILE CONTROLS_SPECIES_TSV MIN_PER_SPECIES \
       INPUTS_DIR OUTPUTS_DIR LOGS_DIR \
       GENOMES_ARCHAEA_DIR GENOMES_CONTROLS_DIR \
       ATB_METADATA ATB_TARBALL_CACHE \
       ARCHAEA_FASTA_LIST CONTROLS_FASTA_LIST CONTROLS_GENUS_MAP \
       PROKKA_OUT PROKKA_CTRL_OUT \
       SPECIES_CALLS_DIR GFF_LISTS_DIR \
       PHASOME_ARCHAEA_BASE PHASOME_CONTROLS_BASE \
       EXTRACTION_DIR EGGNOG_DIR EGGNOG_DB_DIR \
       CLEANED_DIR QUANT_DIR ANALYSIS_DIR FIGURES_DIR \
       SLURM_PARTITION
